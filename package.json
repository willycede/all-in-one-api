{
  "name": "banasystem-backend",
  "version": "1.0.0",
  "description": "backend to dispatch all front request",
  "main": "server.js",
  "scripts": {
    "test": "node app/tests/productCatalogFilters.test.js",
    "start": "nodemon server.js",
    "migrate": "knex migrate:latest",
    "migrate:rollback": "knex migrate:rollback",
    "migrate:favorites": "node app/db/scripts/ensure_user_favorites.js",
    "migrate:coupons": "node app/db/scripts/ensure_coupons.js",
    "migrate:user-security": "node app/db/scripts/ensure_user_security.js",
    "migrate:billing": "node app/db/scripts/ensure_billing_settings.js",
    "verify:billing-invoice": "node app/db/scripts/verify_billing_invoice_payload.js",
    "migrate:audit-logs": "node app/db/scripts/ensure_audit_logs.js",
    "migrate:prod": "node app/db/scripts/baseline_migrations.js && knex migrate:latest",
    "promote:admin": "node app/db/scripts/promote_admin_user.js",
    "disable:2fa": "node app/db/scripts/disable_user_two_factor.js",
    "migrate:baseline": "node app/db/scripts/baseline_migrations.js"
  },
  "author": "Dev Team",
  "license": "ISC",
  "dependencies": {
    "@sendinblue/client": "^3.2.2",
    "aws-sdk": "^2.879.0",
    "axios": "^0.27.2",
    "bcryptjs": "^2.4.3",
    "body-parser": "^1.19.0",
    "cors": "^2.8.5",
    "currency.js": "^2.0.4",
    "dotenv": "^8.2.0",
    "express": "^4.17.1",
    "express-fileupload": "^1.2.1",
    "html-pdf": "^2.2.0",
    "install": "^0.13.0",
    "jsonwebtoken": "^8.5.1",
    "knex": "^0.21.6",
    "moment": "^2.29.1",
    "morgan": "^1.10.0",
    "multer": "^1.4.2",
    "multer-s3": "^2.9.0",
    "mysql": "^2.18.1",
    "mysql2": "^2.2.5",
    "node-forge": "^1.4.0",
    "nodemon": "^2.0.5",
    "npm": "^6.14.8",
    "qrcode": "^1.5.4",
    "sharp": "^0.28.1",
    "sib-api-v3-sdk": "^8.5.0",
    "speakeasy": "^2.0.0"
  }
